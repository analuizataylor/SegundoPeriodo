//código para gerar números pares de 1 a 10
import java.util.Scanner;

public class Main {
	public static void main(String[] args) {
		Scanner entrada = new Scanner(System.in);

		for (int i = 0; i < 10; i = i + 2){
			System.out.println("Valor de i: " + i);
		}

		entrada.close();
	}
}

