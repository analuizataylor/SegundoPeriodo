        System.out.println("Informe o segundo número: ");
        n2 = entrada.nextInt();
        System.out.println("Informe o terceiro número: ");
        n3 = entrada.nextInt();

        int maior = 0;
        if (n1 > maior) {
            maior = n1;
        } if (n2 > maior) {
            maior = n2;
        } else {
